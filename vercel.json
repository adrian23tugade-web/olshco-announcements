{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https:; script-src 'self' https: 'unsafe-inline' 'unsafe-eval'; style-src 'self' https: 'unsafe-inline'; img-src 'self' https: data: blob:; font-src 'self' https: data:; connect-src 'self' https: wss:; frame-ancestors 'self'; upgrade-insecure-requests;"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/login", "destination": "/api/login.php" },
    { "source": "/register", "destination": "/api/register.php" },
    { "source": "/dashboard", "destination": "/api/dashboard.php" },
    { "source": "/profile", "destination": "/api/profile.php" },
    { "source": "/logout", "destination": "/api/logout.php" },
    { "source": "/chat-api", "destination": "/api/chat-api.php" },
    { "source": "/admin", "destination": "/api/admin/dashboard.php" },
    { "source": "/admin/(.*)", "destination": "/api/admin/$1" },
    { "source": "/(.*)\\.php", "destination": "/api/$1.php" }
  ]
}
