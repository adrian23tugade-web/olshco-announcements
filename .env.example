# ============================================================
# .env.example — TEMPLATE ONLY. DO NOT put real values here.
# Add the REAL values in: Vercel Dashboard → Settings → Environment Variables
# ============================================================

# Database Configuration (From https://www.freesqldatabase.com/)
DB_HOST=your_db_host_here
DB_NAME=your_db_name_here
DB_USER=your_db_user_here
DB_PASS=your_db_password_here

# API Keys (Add real values in Vercel Environment Variables - NOT here)
GEMINI_API_KEY=your_gemini_api_key_here
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Application URL (Update after deploying to Vercel)
APP_URL=https://your-project-name.vercel.app
